---
import Base from "../layouts/Base.astro";
import SectionHeading from "../components/SectionHeading.astro";
import EcosystemCard from "../components/EcosystemCard.astro";
import HeroShader from "../components/HeroShader.astro";
import { ECOSYSTEM } from "../data/ecosystem";
import "../styles/slice-precision.css";

/**
 * Direction slice B: COOL-PRECISION.
 * Conceit: the page is a numbered engineering drawing set (SHT 01-04) with a
 * title block, dimension callouts, and figures instead of marketing chrome.
 */
---

<Base
  title="Chimera Werks · Multi-agent tooling, drawn to tolerance"
  description="Chimera Werks builds consoles, run languages, and instruments for engineers who run fleets of coding agents. Flagship: Chimera Relay."
  theme="precision"
>
  <main class="slice-b">
    <!-- ============ SHT 01 · HERO ============ -->
    <section class="relative isolate flex min-h-dvh flex-col overflow-hidden">
      <!-- Swappable backdrop layer: a canvas replaces this element later. -->
      <div id="hero-canvas-slot" class="blueprint-grid absolute inset-0 -z-10" aria-hidden="true">
        <HeroShader />
      </div>
      <script>
        import "../scripts/hero-3d-loader";
      </script>

      <!-- Drafting furniture: accent hairlines + registration crosses. -->
      <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
        <span class="sb-vline left-6 sm:left-10"></span>
        <span
          class="absolute inset-x-0 top-16 h-px bg-linear-to-r from-transparent via-accent/25 to-transparent"
        ></span>
        <span class="sb-cross left-4 top-24"></span>
        <span class="sb-cross right-4 top-24"></span>
        <span class="sb-cross bottom-40 left-4"></span>
        <span class="sb-cross bottom-40 right-4 hidden sm:block"></span>
      </div>

      <div
        class="mx-auto flex w-full max-w-6xl items-center justify-between gap-4 px-6 pt-6 font-mono text-xs"
      >
        <span class="uppercase tracking-[0.2em] text-ink-2">Chimera Werks</span>
        <a
          href="mailto:hello@chimerawerks.com"
          class="text-ink-3 transition-colors hover:text-accent-2"
        >
          hello@chimerawerks.com
        </a>
      </div>

      <div class="mx-auto flex w-full max-w-6xl flex-1 flex-col justify-center px-6 py-16">
        <p
          class="sb-in font-mono text-xs uppercase tracking-[0.22em] text-accent-2"
          style="--d: 0.05s"
        >
          CW-00 · spec sheet · rev 2.0 · SHT 01 / 04
        </p>
        <h1 class="sb-display sb-in mt-6" style="--d: 0.15s">
          Chimera<br />Werks
        </h1>
        <div class="sb-in mt-7 max-w-2xl" style="--d: 0.28s">
          <p class="sb-dim"><span>one studio · many agents · tol ±0.0</span></p>
        </div>
        <p
          class="sb-in mt-8 max-w-xl text-base leading-relaxed text-ink-2 sm:text-lg"
          style="--d: 0.4s"
        >
          A studio building tooling for engineers who run fleets of coding agents: the consoles,
          run languages, and instruments that make a swarm read like one machine.
        </p>
        <div class="sb-in mt-10 flex flex-wrap items-center gap-4" style="--d: 0.52s">
          <a
            href="#ecosystem"
            class="rounded-theme-sm border border-accent bg-accent-dim px-5 py-2.5 font-mono text-xs uppercase tracking-[0.14em] text-accent-hi transition-colors hover:bg-accent hover:text-bg"
          >
            Instrument index
          </a>
          <a
            href="#flagship"
            class="rounded-theme-sm border border-line-2 px-5 py-2.5 font-mono text-xs uppercase tracking-[0.14em] text-ink-2 transition-colors hover:border-accent-2 hover:text-accent-2"
          >
            Flagship: Chimera Relay
          </a>
        </div>
      </div>

      <div
        class="mx-auto flex w-full max-w-6xl flex-wrap items-end justify-between gap-6 px-6 pb-8"
      >
        <a
          href="#ecosystem"
          class="font-mono text-[0.6875rem] uppercase tracking-[0.16em] text-ink-3 transition-colors hover:text-ink-2"
        >
          scroll · SHT 02 ↓
        </a>
        <div class="sb-titleblock sb-in" style="--d: 0.6s">
          <div class="tb-head">Chimera Werks · multi-agent tooling</div>
          <div class="tb-k">dwg no.</div>
          <div class="tb-v">CW-00</div>
          <div class="tb-k">rev</div>
          <div class="tb-v">2.0</div>
          <div class="tb-k">scale</div>
          <div class="tb-v">1 : 1</div>
          <div class="tb-k">sheet</div>
          <div class="tb-v">01 of 04</div>
        </div>
      </div>
    </section>

    <!-- ============ SHT 02 · ECOSYSTEM ============ -->
    <section id="ecosystem" class="border-t border-line-1">
      <div class="mx-auto max-w-6xl px-6 py-24 sm:py-28">
        <div class="sb-reveal flex flex-wrap items-end justify-between gap-6">
          <SectionHeading kicker="SHT 02 / 04 · instrument index" heading="The ecosystem" />
          <p class="max-w-md text-sm leading-relaxed text-ink-2">
            Every instrument here runs in our own werkshop daily. Each exists because operating an
            agent fleet demanded it; none is speculative.
          </p>
        </div>
        <div class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {
            ECOSYSTEM.map((app) => (
              <div
                class:list={[
                  "sb-reveal",
                  app.flagship && "sm:col-span-2",
                  app.id === "more" && "sm:col-span-2 lg:col-span-3",
                ]}
              >
                <EcosystemCard app={app} />
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ============ SHT 03 · FLAGSHIP ============ -->
    <section id="flagship" class="border-t border-line-1">
      <div class="mx-auto max-w-6xl px-6 py-24 sm:py-28">
        <div class="sb-reveal">
          <SectionHeading kicker="SHT 03 / 04 · flagship" heading="Chimera Relay" />
          <p class="mt-4 max-w-2xl text-base leading-relaxed text-ink-2">
            The orchestration console the rest of the werks hangs off. Rooms of agents (Codex,
            Claude, Hermes, local models) run, argue, and get judged behind one pane of glass.
          </p>
        </div>

        <div class="mt-16 flex flex-col gap-16 sm:gap-20">
          <!-- Beat 01 -->
          <div class="sb-reveal grid items-center gap-8 lg:grid-cols-2 lg:gap-14">
            <div>
              <p class="font-mono text-xs uppercase tracking-[0.18em] text-ink-3">B-01</p>
              <h3 class="mt-2 font-display text-2xl font-semibold text-ink-1">
                One console, whole fleet
              </h3>
              <div class="mt-6 space-y-5">
                <div>
                  <p class="font-mono text-[0.6875rem] uppercase tracking-[0.16em] text-ink-3">
                    Problem
                  </p>
                  <p class="mt-1.5 text-sm leading-relaxed text-ink-2">
                    Every agent you add is another terminal to babysit, another transcript
                    scrolling somewhere you are not looking.
                  </p>
                </div>
                <div>
                  <p class="font-mono text-[0.6875rem] uppercase tracking-[0.16em] text-accent-2">
                    Solution
                  </p>
                  <p class="mt-1.5 text-sm leading-relaxed text-ink-2">
                    Relay puts the fleet in shared rooms: personas, live transcripts, spawn
                    controls. However many agents are running, you watch one console.
                  </p>
                </div>
              </div>
            </div>
            <figure class="sb-fig">
              <svg
                viewBox="0 0 460 280"
                role="img"
                aria-label="Schematic: four agent harnesses fanning into a single Relay room"
              >
                <rect class="sb-node" x="24" y="22" width="116" height="40" rx="6"></rect>
                <text class="sb-label" x="82" y="46" text-anchor="middle">CODEX-01</text>
                <rect class="sb-node" x="24" y="88" width="116" height="40" rx="6"></rect>
                <text class="sb-label" x="82" y="112" text-anchor="middle">CLAUDE-02</text>
                <rect class="sb-node" x="24" y="154" width="116" height="40" rx="6"></rect>
                <text class="sb-label" x="82" y="178" text-anchor="middle">HERMES-03</text>
                <rect class="sb-node" x="24" y="220" width="116" height="40" rx="6"></rect>
                <text class="sb-label" x="82" y="244" text-anchor="middle">LOCAL-04</text>

                <path class="sb-edge sb-flow" d="M140 42 C 224 42, 224 108, 308 108"></path>
                <path class="sb-edge sb-flow" d="M140 108 C 224 108, 224 128, 308 128"></path>
                <path class="sb-edge sb-flow" d="M140 174 C 224 174, 224 152, 308 152"></path>
                <path class="sb-edge sb-flow" d="M140 240 C 224 240, 224 172, 308 172"></path>
                <circle class="sb-dot" cx="140" cy="42" r="2.5"></circle>
                <circle class="sb-dot" cx="140" cy="108" r="2.5"></circle>
                <circle class="sb-dot" cx="140" cy="174" r="2.5"></circle>
                <circle class="sb-dot" cx="140" cy="240" r="2.5"></circle>

                <rect class="sb-node-accent" x="308" y="86" width="128" height="108" rx="6"></rect>
                <text class="sb-label-hi" x="372" y="106" text-anchor="middle">RELAY · ROOM A</text>
                <line class="sb-rule" x1="324" y1="126" x2="420" y2="126"></line>
                <line class="sb-rule" x1="324" y1="144" x2="404" y2="144"></line>
                <line class="sb-rule" x1="324" y1="162" x2="414" y2="162"></line>
                <line class="sb-rule" x1="324" y1="180" x2="392" y2="180"></line>
              </svg>
              <figcaption class="sb-figcap">Fig. 1 · fan-in: four harnesses, one room</figcaption>
            </figure>
          </div>

          <!-- Beat 02 -->
          <div class="sb-reveal grid items-center gap-8 lg:grid-cols-2 lg:gap-14">
            <div class="lg:order-2">
              <p class="font-mono text-xs uppercase tracking-[0.18em] text-ink-3">B-02</p>
              <h3 class="mt-2 font-display text-2xl font-semibold text-ink-1">
                Orchestration you can diff
              </h3>
              <div class="mt-6 space-y-5">
                <div>
                  <p class="font-mono text-[0.6875rem] uppercase tracking-[0.16em] text-ink-3">
                    Problem
                  </p>
                  <p class="mt-1.5 text-sm leading-relaxed text-ink-2">
                    Judge panels, fusion runs, debates: in most shops that logic lives in glue
                    scripts only the author can rerun.
                  </p>
                </div>
                <div>
                  <p class="font-mono text-[0.6875rem] uppercase tracking-[0.16em] text-accent-2">
                    Solution
                  </p>
                  <p class="mt-1.5 text-sm leading-relaxed text-ink-2">
                    Relay executes Chimera DNA, a declarative run format. An orchestration becomes
                    a document: readable, diffable, rerunnable on any harness.
                  </p>
                </div>
              </div>
            </div>
            <figure class="sb-fig lg:order-1">
              <div class="sb-spec overflow-x-auto">
                <span class="sb-line"><span><span class="text-ink-1">run</span> "triage-panel" &#123;</span></span>
                <span class="sb-line"><span>&nbsp;&nbsp;<span class="sb-key">pattern</span><span class="sb-val">judge-panel</span></span></span>
                <span class="sb-line"><span>&nbsp;&nbsp;<span class="sb-key">candidates</span><span class="sb-val">3 × codex</span></span></span>
                <span class="sb-line"><span>&nbsp;&nbsp;<span class="sb-key">judge</span><span class="sb-val">1 × claude</span></span></span>
                <span class="sb-line"><span>&nbsp;&nbsp;<span class="sb-key">output</span><span class="sb-val">verdict → room</span></span></span>
                <span class="sb-line"><span>&#125;</span></span>
              </div>
              <figcaption class="sb-figcap">
                Fig. 2 · a DNA run: the whole orchestration in six lines
              </figcaption>
            </figure>
          </div>

          <!-- Beat 03 -->
          <div class="sb-reveal grid items-center gap-8 lg:grid-cols-2 lg:gap-14">
            <div>
              <p class="font-mono text-xs uppercase tracking-[0.18em] text-ink-3">B-03</p>
              <h3 class="mt-2 font-display text-2xl font-semibold text-ink-1">
                Failures keep their trail
              </h3>
              <div class="mt-6 space-y-5">
                <div>
                  <p class="font-mono text-[0.6875rem] uppercase tracking-[0.16em] text-ink-3">
                    Problem
                  </p>
                  <p class="mt-1.5 text-sm leading-relaxed text-ink-2">
                    Multi-agent failures arrive as one normalized reason code, with the real stderr
                    swallowed three process hops down.
                  </p>
                </div>
                <div>
                  <p class="font-mono text-[0.6875rem] uppercase tracking-[0.16em] text-accent-2">
                    Solution
                  </p>
                  <p class="mt-1.5 text-sm leading-relaxed text-ink-2">
                    Relay's diagnostics preserve the raw RPC trail: child stderr included, secrets
                    redacted, loopback-only. Root cause takes minutes, not an evening.
                  </p>
                </div>
              </div>
            </div>
            <figure class="sb-fig">
              <svg
                viewBox="0 0 460 230"
                role="img"
                aria-label="Schematic: a run timeline where the failing event expands into its preserved error trail"
              >
                <line class="sb-rule" x1="24" y1="52" x2="436" y2="52"></line>
                <line class="sb-rule" x1="24" y1="47" x2="24" y2="57"></line>
                <line class="sb-rule" x1="127" y1="47" x2="127" y2="57"></line>
                <line class="sb-rule" x1="230" y1="47" x2="230" y2="57"></line>
                <line class="sb-rule" x1="333" y1="47" x2="333" y2="57"></line>
                <line class="sb-rule" x1="436" y1="47" x2="436" y2="57"></line>

                <circle class="sb-dot" cx="70" cy="52" r="3"></circle>
                <text class="sb-label-dim" x="70" y="32" text-anchor="middle">SPAWN</text>
                <circle class="sb-dot" cx="178" cy="52" r="3"></circle>
                <text class="sb-label-dim" x="178" y="32" text-anchor="middle">DISPATCH</text>
                <circle class="sb-dot" cx="286" cy="52" r="3"></circle>
                <text class="sb-label-dim" x="286" y="32" text-anchor="middle">STREAM</text>
                <circle class="sb-bad-fill" cx="394" cy="52" r="4"></circle>
                <text class="sb-bad-fill" x="394" y="32" text-anchor="middle">EXIT 127</text>

                <path class="sb-bad-stroke" d="M394 56 L394 88 L330 88 L330 96"></path>

                <rect class="sb-node" x="110" y="96" width="326" height="104" rx="6"></rect>
                <text class="sb-label-dim" x="128" y="124">$ relay-diag last --room a</text>
                <text class="sb-label" x="128" y="148">codex.spawn → exit 127</text>
                <text class="sb-bad-fill" x="128" y="172">stderr: ENOENT ./harness (preserved)</text>
              </svg>
              <figcaption class="sb-figcap">Fig. 3 · the trail survives every hop</figcaption>
            </figure>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ SHT 04 · CONTACT ============ -->
    <section id="contact" class="border-t border-line-1">
      <div class="mx-auto max-w-6xl px-6 py-24 sm:py-28">
        <div class="sb-reveal max-w-2xl">
          <SectionHeading kicker="SHT 04 / 04 · transmissions" heading="Send a signal" />
          <p class="mt-4 text-base leading-relaxed text-ink-2">
            Consulting, collaboration, or curiosity about what is on the bench: mail is read by a
            human, not routed to a room.
          </p>
          <div class="mt-8">
            <a
              href="mailto:hello@chimerawerks.com"
              class="inline-block rounded-theme-sm border border-accent-2 bg-accent-2-dim px-5 py-2.5 font-mono text-xs uppercase tracking-[0.14em] text-accent-2-hi transition-colors hover:bg-accent-2 hover:text-bg"
            >
              hello@chimerawerks.com
            </a>
          </div>
          <p class="mt-10 font-mono text-xs text-ink-3">
            Site archive:
            <a
              href="/archive/v1/"
              class="underline decoration-line-2 underline-offset-4 transition-colors hover:text-ink-2"
            >
              v1 (Chimera Studio era)
            </a>
          </p>
        </div>
      </div>
    </section>

    <footer class="border-t border-line-1">
      <div
        class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-3 px-6 py-8 font-mono text-[0.6875rem] uppercase tracking-[0.12em] text-ink-3"
      >
        <p>© 2026 Chimera Werks</p>
        <p>DWG CW-00 · rev 2.0 · end of set</p>
      </div>
    </footer>
  </main>
</Base>
