---
/**
 * Direction slice A: "warm-arcane evolved".
 * Relay's operator-console aesthetic loosened for marketing scale: void
 * graphite, parchment ink, iris + amber signature pair, one ceremonial
 * Cinzel word, and a ritual-gauge hero background awaiting its shader.
 */
import Base from "../layouts/Base.astro";
import SectionHeading from "../components/SectionHeading.astro";
import EcosystemCard from "../components/EcosystemCard.astro";
import StatusDot from "../components/StatusDot.astro";
import HeroShader from "../components/HeroShader.astro";
import { ECOSYSTEM } from "../data/ecosystem";
import "../styles/slice-arcane.css";

/* Per-letter delays for the wordmark's kinetic reveal; CSS reads --d. */
const LETTER_STEP_MS = 42;
let cursor = 0;
const HEADLINE = ["Chimera", "Werks"].map((word) =>
  word.split("").map((ch) => ({ ch, d: cursor++ * LETTER_STEP_MS })),
);
const PERIOD_DELAY = cursor * LETTER_STEP_MS;

/* Generated, illustrative room state for the console composition (decorative,
   aria-hidden). Persona hues echo the ecosystem card identity system. */
const LANES = [
  { name: "oracle", hue: 6, task: "drafting the migration plan", pct: 82 },
  { name: "mason", hue: 0, task: "implementing relay-core #214", pct: 64 },
  { name: "warden", hue: 2, task: "adversarial review, pass two", pct: 47 },
  { name: "courier", hue: 3, task: "syncing artifacts to the room", pct: 91 },
  { name: "scribe", hue: 1, task: "writing the handoff", pct: 33 },
];

const BEATS = [
  {
    problem: "Ten agents means ten terminals and zero peripheral vision.",
    solution:
      "Relay puts the whole fleet in shared rooms: every agent, every message, every artifact on one screen, live.",
  },
  {
    problem: "A single prompt to a single agent does not survive contact with real work.",
    solution:
      "DNA runs compose fusion, debate, and judge panels across Codex, Claude, Hermes, and local models. Declared once, executed anywhere.",
  },
  {
    problem: "And when an agent dies, most consoles hand you a normalized reason code.",
    solution:
      "Relay keeps the raw trail: stderr, RPC hops, exit codes. The real error is one layer down, never gone.",
  },
];
---

<Base
  title="Chimera Werks · Many agents, one beast"
  description="Chimera Werks builds multi-agent tooling: Chimera Relay, DNA, Library, Browser, and Image Lab. Fleets of coding agents, run as one."
  theme="arcane"
>
  <main>
    <!-- ============================================================ hero -->
    <section class="hero vignette grain relative isolate flex min-h-dvh flex-col overflow-hidden">
      <div class="hairline-signature absolute inset-x-0 top-0"></div>

      <!-- Swappable background layer: a shader canvas replaces the children
           of this slot later. Keep the id stable. -->
      <div id="hero-canvas-slot" aria-hidden="true">
        <div class="hero-veil"></div>
        <div class="ring-field">
          <div class="ring ring-ticks"></div>
          <div class="ring ring-ticks-inner"></div>
          <div class="ring ring-line"></div>
          <div class="ring ring-arc"></div>
          <div class="ring-core"></div>
        </div>
        <HeroShader />
      </div>
      <script>
        import "../scripts/hero-3d-loader";
      </script>

      <div class="relative mx-auto flex w-full max-w-6xl flex-1 flex-col justify-center px-6 pb-32 pt-24 sm:px-10">
        <p class="hero-kicker rise font-mono" style="--d: 0ms">// many hands make light werk</p>

        <h1 class="hero-display font-display">
          <span class="sr-only">Chimera Werks</span>
          <span aria-hidden="true">
            {
              HEADLINE.map((line, i) => (
                <span class="hero-line">
                  {line.map((l) => (
                    // prettier-ignore
                    <span class="hero-letter" style={`--d: ${l.d}ms`}>{l.ch}</span>
                  ))}
                  {i === HEADLINE.length - 1 && (
                    // prettier-ignore
                    <span class="hero-letter hero-period" style={`--d: ${PERIOD_DELAY}ms`}>.</span>
                  )}
                </span>
              ))
            }
          </span>
        </h1>

        <p class="hero-thesis rise" style="--d: 640ms">
          Many agents. One <span class="word-arcane">Beast</span>.
        </p>

        <p class="rise mt-5 max-w-xl text-[1.0625rem] leading-relaxed text-ink-2" style="--d: 780ms">
          We build the rooms, the language, and the instruments that let a fleet of coding agents -
          Codex, Claude, Hermes, and stranger things - work a single problem as one animal.
        </p>

        <div class="rise mt-9 flex flex-wrap items-center gap-4" style="--d: 920ms">
          <a href="#werks" class="btn btn-primary">Survey the werks</a>
          <a href="mailto:hello@chimerawerks.com" class="btn btn-ghost">hello@chimerawerks.com</a>
        </div>
      </div>

      <div class="scroll-cue rise" style="--d: 1300ms" aria-hidden="true">
        <span class="font-mono text-[0.6875rem] uppercase tracking-[0.2em] text-ink-3">scroll</span>
        <span class="scroll-cue-line"></span>
      </div>
    </section>

    <!-- ======================================================= ecosystem -->
    <section id="werks" class="border-t border-line-1">
      <div class="mx-auto max-w-6xl px-6 py-24 sm:px-10 sm:py-28">
        <SectionHeading kicker="the werks" heading="Every head of the beast" />
        <p class="mt-4 max-w-2xl text-ink-2">
          Every tool ships from the same bench and speaks the same identity system: shared hues,
          shared statuses, shared rooms across the fleet.
        </p>

        <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {
            ECOSYSTEM.map((app) => (
              <div
                class:list={[
                  "eco-cell reveal-view",
                  app.flagship && "sm:col-span-2",
                  app.id === "more" && "sm:col-span-2 lg:col-span-3",
                ]}
              >
                <EcosystemCard app={app} />
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ======================================================== flagship -->
    <section id="relay" class="border-t border-line-1">
      <div
        class="mx-auto grid max-w-6xl gap-14 px-6 py-24 sm:px-10 sm:py-28 lg:grid-cols-[1fr_1.05fr] lg:items-center"
      >
        <div>
          <SectionHeading kicker="flagship werk" heading="Chimera Relay" />
          <p class="mt-4 text-lg text-ink-2">The console where the swarm reports for duty.</p>

          <div class="mt-10 flex flex-col gap-8">
            {
              BEATS.map((beat) => (
                <div class="beat">
                  <p class="beat-problem">
                    <span class="mark mark-bad">×</span>
                    <span>{beat.problem}</span>
                  </p>
                  <p class="beat-solution">
                    <span class="mark mark-good">→</span>
                    <span>{beat.solution}</span>
                  </p>
                </div>
              ))
            }
          </div>
        </div>

        <div class="console-wrap reveal-view" aria-hidden="true">
          <div class="console">
            <div class="console-head">
              <span>relay · room/night-werks</span>
              <span class="pill">
                <StatusDot status="active" hue="var(--accent-2)" />
                live
              </span>
            </div>
            <div>
              {
                LANES.map((lane) => (
                  <div class="lane spine" style={`--hue: var(--card-hue-${lane.hue})`}>
                    <div class="lane-top">
                      <span class="lane-name">{lane.name}</span>
                      <span class="lane-pct">{lane.pct}%</span>
                    </div>
                    <p class="lane-task">{lane.task}</p>
                    <div class="gauge">
                      <i style={`--w: ${lane.pct}%`}></i>
                    </div>
                  </div>
                ))
              }
            </div>
            <div class="console-foot">
              <span>judge panel · 3 verdicts in</span>
              <span>dna: fusion-3</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========================================================= contact -->
    <section id="contact" class="border-t border-line-1 bg-surface-1">
      <div
        class="mx-auto flex max-w-6xl flex-col gap-8 px-6 py-20 sm:flex-row sm:items-end sm:justify-between sm:px-10"
      >
        <div class="min-w-0">
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-accent">// open a channel</p>
          <a href="mailto:hello@chimerawerks.com" class="contact-mail mt-3">hello@chimerawerks.com</a>
          <p class="mt-3 text-sm text-ink-2">One inbox. A human answers.</p>
        </div>
        <a
          href="/archive/v1/"
          class="font-mono text-xs text-ink-2 underline decoration-line-2 underline-offset-4 transition-colors hover:text-ink-1"
        >
          Site archive: v1 (Chimera Studio era)
        </a>
      </div>
    </section>
  </main>

  <footer class="relative border-t border-line-1">
    <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-10 text-xs sm:px-10">
      <span class="text-ink-3">© 2026 Chimera Werks</span>
      <span class="font-mono text-ink-3">many hands · light werk</span>
    </div>
    <div class="hairline-signature"></div>
  </footer>
</Base>
