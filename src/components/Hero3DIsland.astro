---
/**
 * Astro island wrapper for the Hero3D R3F scene.
 *
 * Drop inside a slice hero's #hero-canvas-slot (both slices style that slot
 * as absolute/inset-0 behind the headline). client:only="react" defers all
 * work to the browser; the component itself gates on reduced motion, WebGL
 * support, viewport intersection, and tab visibility, so the static CSS
 * background beneath remains the no-JS / reduced-motion fallback.
 */
import Hero3D from "./Hero3D";
---

<div class="hero3d" aria-hidden="true">
  <Hero3D client:only="react" />
</div>

<style>
  .hero3d {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .hero3d :global(canvas) {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
