---
import type { EcosystemApp } from "../data/ecosystem";
import StatusDot from "./StatusDot.astro";

interface Props {
  app: EcosystemApp;
}

const { app } = Astro.props;
const hue = `var(--card-hue-${app.hueIndex})`;
---

<article
  class="spine flex h-full flex-col gap-3 rounded-theme border border-line-1 bg-surface-2 p-5 pl-6"
  style={`--hue: ${hue}`}
>
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <h3 class="font-display text-lg font-semibold text-ink-1">{app.name}</h3>
      <p class="mt-0.5 text-sm text-ink-2">{app.tagline}</p>
    </div>
    <span class="pill mt-1">
      <StatusDot status={app.status} hue={hue} />
      {app.status}
    </span>
  </div>
  <p class="text-sm leading-relaxed text-ink-2">{app.blurb}</p>
</article>
