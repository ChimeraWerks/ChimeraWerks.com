---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import type { EcosystemApp } from "../data/ecosystem";
import StatusDot from "./StatusDot.astro";

interface Props {
  app: EcosystemApp;
  /** Optional engraved seal, rendered as a faint backdrop mark (dir-c). */
  emblem?: ImageMetadata;
}

const { app, emblem } = Astro.props;
const hue = `var(--card-hue-${app.hueIndex})`;
---

<article
  class="spine relative flex h-full flex-col gap-3 overflow-hidden rounded-theme border border-line-1 bg-surface-2 p-5 pl-6"
  style={`--hue: ${hue}`}
>
  {
    emblem && (
      <Image
        src={emblem}
        alt=""
        width={220}
        densities={[1, 2]}
        loading="lazy"
        decoding="async"
        aria-hidden="true"
        class="eco-emblem"
      />
    )
  }
  <div class="relative flex items-start justify-between gap-3">
    <div class="min-w-0">
      <h3 class="font-display text-lg font-semibold text-ink-1">{app.name}</h3>
      <p class="mt-0.5 text-sm text-ink-2">{app.tagline}</p>
    </div>
    <span class="pill mt-1">
      <StatusDot status={app.status} hue={hue} />
      {app.status}
    </span>
  </div>
  <p class="relative text-sm leading-relaxed text-ink-2">{app.blurb}</p>
</article>

<style>
  /* Engraved seal bleeding off the card's bottom-right corner; faint enough
     to read as texture, never competing with the copy. screen-blend drops
     the emblem's black plate into the card surface (assets are engraved on
     #000, not transparent — the OAuth image backend rejects transparency). */
  .eco-emblem {
    position: absolute;
    right: -34px;
    bottom: -44px;
    width: 170px;
    height: auto;
    opacity: 0.34;
    mix-blend-mode: screen;
    pointer-events: none;
  }
</style>
