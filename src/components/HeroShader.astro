---
/**
 * WebGL smoke backdrop for the hero. Drop anywhere inside the hero
 * <section>; at runtime the canvas moves itself into #hero-canvas-slot and
 * fades in over the existing CSS background. That CSS background is the
 * permanent fallback: reduced-motion, missing WebGL, or a lost context all
 * remove the canvas and leave the slot exactly as authored.
 *
 * Theme-aware by construction — colors come from the --bg / --accent /
 * --accent-2 tokens on <html data-theme> at init, so the arcane slice gets
 * iris+amber smoke and the precision slice gets violet+cyan from the same
 * program. Logic lives in src/scripts/hero-shader.ts.
 */
---

<canvas class="hero-shader-canvas" aria-hidden="true"></canvas>

<script>
  import { mountHeroShader } from "../scripts/hero-shader";

  // Demo scaffolding for the hero pick: ?hero=3d|css suppresses the shader
  // so the alternate variant (or bare CSS background) can be judged. Remove
  // the gate once the owner picks a hero.
  const variant = new URLSearchParams(location.search).get("hero") ?? "shader";
  if (variant === "shader") {
    for (const canvas of document.querySelectorAll<HTMLCanvasElement>("canvas.hero-shader-canvas")) {
      mountHeroShader(canvas);
    }
  } else {
    document.querySelectorAll("canvas.hero-shader-canvas").forEach((c) => c.remove());
  }
</script>

<style>
  .hero-shader-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0;
    transition: opacity 600ms ease;
  }

  .hero-shader-canvas.is-live {
    opacity: 1;
  }

  /* Belt and braces: if the script never runs, an inert transparent canvas
     must not linger over the hero on printouts or reader modes. */
  @media (prefers-reduced-motion: reduce) {
    .hero-shader-canvas {
      display: none;
    }
  }
</style>
